# MillForge Backend — Environment Variables
# Copy this to .env and fill in your keys.
# Lines starting with # are comments.

# ── Local LLM (discovery agent / NL scheduler) ────────────────────────────────
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# ── EIA API (real PJM energy pricing + Census ASM production data) ────────────
# Free key at: https://www.eia.gov/opendata/register.php  (takes ~2 min)
# Without this, energy rates and production planner use simulated data.
EIA_API_KEY=your_eia_key_here

# ── Electricity Maps (live carbon intensity by grid zone) ─────────────────────
# Free tier at: https://api.electricitymap.org/free-tier  (no CC required)
# Without this, carbon intensity uses EPA 2023 average (0.386 kg/kWh).
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here

# ── MTConnect (real CNC machine telemetry) ────────────────────────────────────
# Set to your machine's MTConnect agent URL, e.g. http://192.168.1.100:5000
# Without this, machine status uses synthetic rotating states (dev mode).
# MTCONNECT_AGENT_URL=http://192.168.1.100:5000

# ── Auth / Session ────────────────────────────────────────────────────────────
# Required in production. Any long random string works.
# SECRET_KEY=change-me-in-production

# ── Railway deployment ────────────────────────────────────────────────────────
# Set automatically by Railway — do not set manually.
# RAILWAY_ENVIRONMENT=production
# DATABASE_URL=postgresql://...
