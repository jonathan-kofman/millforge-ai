# MillForge Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# --- Auth ---
SECRET_KEY=

# --- Database ---
# Leave blank to use SQLite locally. Set to a Postgres URL on Railway / Supabase.
# Supabase format (Session Mode pooler, port 5432):
#   DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Direct connection (no pooler):
#   DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# --- CORS ---
# Comma-separated list of allowed frontend origins (dev defaults below).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend URL (production) ---
# Set this on Railway so the backend allows your Vercel deployment.
# Example: FRONTEND_URL=https://millforge-ai.vercel.app
FRONTEND_URL=

# --- Railway (set automatically by Railway, do not set manually) ---
# RAILWAY_ENVIRONMENT is injected by Railway and enables secure httpOnly cookies.
# RAILWAY_ENVIRONMENT=production

# --- AI ---
ANTHROPIC_API_KEY=

# --- Contact form email notifications ---
# SMTP_EMAIL and SMTP_PASSWORD must both be set to enable email alerts.
# IMPORTANT: SMTP_PASSWORD must be a Gmail App Password — NOT your regular Gmail password.
# To generate: Google Account → Security → 2-Step Verification → App Passwords
#   → select "Mail" → Generate → paste the 16-character code below.
SMTP_EMAIL=
SMTP_PASSWORD=

# --- Energy and Carbon Intensity (optional) ---
# Electricity Maps API key for live carbon intensity (gCO2/kWh) and real-time grid data.
# Sign up: https://electricitymap.org
ELECTRICITY_MAPS_API_KEY=

# --- EIA API for US Census ASM manufacturing benchmarks (optional) ---
# US Energy Information Administration API key for real industry throughput data.
# DEMO_KEY allows ~100 requests/day; sign up for a full key: https://www.eia.gov/opendata/register/
# If not set, MillForge uses internal throughput benchmarks.
EIA_API_KEY=

# --- Kaggle credentials for NEU Surface Defect Database (optional, for vision model training) ---
# Required to download the NEU-DET dataset via Kaggle API when training the vision model.
# Sign up: https://www.kaggle.com/settings/account → Create New API Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Energy pricing API (optional, legacy) ---
# ENERGY_API_KEY=
# ENERGY_API_URL=
