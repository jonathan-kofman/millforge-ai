# MillForge Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# --- Auth ---
SECRET_KEY=

# --- Database ---
# Leave blank to use SQLite locally. Set to a Postgres URL on Railway.
DATABASE_URL=

# --- CORS ---
# Comma-separated list of allowed frontend origins (dev defaults below).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend URL (production) ---
# Set this on Railway so the backend allows your Vercel deployment.
FRONTEND_URL=

# --- AI ---
ANTHROPIC_API_KEY=

# --- Energy pricing API (optional) ---
# ENERGY_API_KEY=
# ENERGY_API_URL=
