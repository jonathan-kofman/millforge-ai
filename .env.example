# MillForge Environment Variables
# Copy this file to .env and fill in your values.

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Future AI integrations ---

# OpenAI API key (for LLM-enhanced scheduling explanations)
OPENAI_API_KEY=sk-...

# Anthropic API key (for Claude-powered planning agent)
ANTHROPIC_API_KEY=sk-ant-...

# --- Future database ---
# DATABASE_URL=postgresql://user:password@localhost:5432/millforge

# --- Future energy pricing API ---
# ENERGY_API_KEY=...
# ENERGY_API_URL=https://api.eia.gov/v2/electricity/...
